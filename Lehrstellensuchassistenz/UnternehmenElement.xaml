<Page x:Class="Lehrstellensuchassistenz.UnternehmenElement"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:Lehrstellensuchassistenz"
    Title="UnternehmenElement">

    <Grid Background="{StaticResource BackgroundBrush}">

        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Oben -->
            <RowDefinition Height="*"/>
            <!-- Mitte -->
            <RowDefinition Height="Auto"/>
            <!-- Unten -->
        </Grid.RowDefinitions>

        <!-- COLUMNS -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Links -->
            <ColumnDefinition Width="Auto"/>
            <!-- Rechts (Foto) -->
        </Grid.ColumnDefinitions>

        <!-- 🔹 OBEN LINKS: Editable Felder nebeneinander -->
        <StackPanel Grid.Row="0" Grid.Column="0" Margin="10">
            <!-- Name -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Name:" FontSize="25" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" FontSize="25"/>
            </Grid>

            <!-- Website mit Öffnen-Button -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Link:" FontSize="20" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Website, UpdateSourceTrigger=PropertyChanged}" FontSize="20" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Width="30" Height="30" Margin="5,0,0,0" Content="↗" ToolTip="Link öffnen" Click="OpenLink_Click"/>
            </Grid>

            <!-- Status -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Status:" FontSize="20" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" SelectedItem="{Binding BewerbungsStatus, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Width="200" ItemsSource="{x:Static local:StatusValues.All}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="15" Padding="3">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <!-- Unbeworben -->
                                            <DataTrigger Binding="{Binding}" Value="Unbeworben">
                                                <DataTrigger.Setters>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Background" Value="Gray"/>
                                                </DataTrigger.Setters>
                                            </DataTrigger>

                                            <!-- Beworben -->
                                            <DataTrigger Binding="{Binding}" Value="Beworben">
                                                <DataTrigger.Setters>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Background" Value="DarkBlue"/>
                                                </DataTrigger.Setters>
                                            </DataTrigger>

                                            <!-- Abgelehnt -->
                                            <DataTrigger Binding="{Binding}" Value="Abgelehnt">
                                                <DataTrigger.Setters>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Background" Value="DarkRed"/>
                                                </DataTrigger.Setters>
                                            </DataTrigger>

                                            <!-- NächsteSchritte -->
                                            <DataTrigger Binding="{Binding}" Value="NächsteSchritte">
                                                <DataTrigger.Setters>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Background" Value="DarkOrange"/>
                                                </DataTrigger.Setters>
                                            </DataTrigger>

                                            <!-- Praktikum -->
                                            <DataTrigger Binding="{Binding}" Value="Praktikum">
                                                <DataTrigger.Setters>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Background" Value="DarkGreen"/>
                                                </DataTrigger.Setters>
                                            </DataTrigger>

                                            <!-- Angenommen -->
                                            <DataTrigger Binding="{Binding}" Value="Angenommen">
                                                <DataTrigger.Setters>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Background" Value="#06B021"/>
                                                </DataTrigger.Setters>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Erstellt:" FontSize="20" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding ErstellDatumMitZeit}" VerticalAlignment="Center" FontSize="20"/>
            </Grid>
        </StackPanel>

        <!-- 🔹 OBEN RECHTS: Klickbarer Foto-Platzhalter -->
        <Button Grid.Row="0" Grid.Column="1" Width="250" Height="250" Margin="10" Click="Select_Photo_Click" Background="Transparent" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <Image x:Name="PhotoPreview" Stretch="UniformToFill"/>
                <TextBlock x:Name="PhotoPlaceholderText" Text="Foto auswählen" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
            </Grid>
        </Button>

        <!-- 🔹 MITTE: Notizen -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Notizen:" Margin="0,0,0,5" FontSize="20"/>
                <TextBox Grid.Row="1" Text="{Binding Notizen, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="15"/>
            </Grid>
        </Border>

        <!-- 🔹 UNTEN: Buttons links & rechts -->
        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" Height="35">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 🔹 Linker Button: Bewerben -->
            <Button Grid.Row="2" 
                Content="Bewerben!" 
                Width="110" 
                Height="25" 
                Margin="5" 
                FontSize="15" 
                FontWeight="SemiBold" 
                Background="#4CAF50" 
                Foreground="White" 
                Visibility="{Binding KannSichBewerben, Converter={StaticResource BoolToVisibilityConverter}}" 
                Click="Bewerben_Click"/>
            
            <Button Grid.Column="1" 
        x:Name="ContinueButton" 
        Content="Schreiben fortsetzen" 
        Width="160" 
        Height="25" 
        Margin="5,0,0,0" 
        FontSize="15" 
        FontWeight="SemiBold" 
        Background="#2196F3" 
        Foreground="White" 
        Visibility="{Binding LetzteBewerbungPfad, Converter={StaticResource NullToVisibilityConverter}}" 
        Click="ContinueButton_Click"/>
            
            <!-- 🔹 Rechte Buttons -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Bewerbungstipps" Width="110" Margin="5" Click="Tipps_Click"/>
                <Button Content="Lebenslauftipps" Width="110" Margin="5" Click="Tipps_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>