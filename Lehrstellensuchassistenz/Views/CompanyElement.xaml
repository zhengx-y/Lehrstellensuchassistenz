<Page x:Class="Lehrstellensuchassistenz.Views.CompanyElement"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Lehrstellensuchassistenz.Views"
      xmlns:models="clr-namespace:Lehrstellensuchassistenz.Models"
      xmlns:converters="clr-namespace:Lehrstellensuchassistenz.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Firma Details">

    <Page.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </Page.Resources>

    <Grid Background="{StaticResource BackgroundBrush}" 
          Focusable="True" 
          MouseDown="Grid_MouseDown">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Margin="15">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Name:" FontSize="22" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" 
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                         FontSize="22"/>
            </Grid>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Link:" FontSize="18" Foreground="Black" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" 
                         Text="{Binding Website, UpdateSourceTrigger=PropertyChanged}" 
                         FontSize="16" 
                         VerticalAlignment="Center" />
                <Button Grid.Column="2" Width="30" Height="30" Margin="5,0,0,0" Content="↗" Click="OpenLink_Click"/>
            </Grid>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Status:" FontSize="18" Foreground="Black" VerticalAlignment="Center"/>

                <ComboBox Grid.Column="1" 
              SelectedValue="{Binding Status, UpdateSourceTrigger=PropertyChanged}" 
              HorizontalAlignment="Left" 
              Width="250" 
              ItemsSource="{x:Static models:StatusValues.All}"
              Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
              Foreground="White"
              FontWeight="SemiBold"
              VerticalContentAlignment="Center">

                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="10" Height="10" 
                             Fill="{Binding Converter={StaticResource StatusToColorConverter}}" 
                             Margin="5,0,10,0" 
                             VerticalAlignment="Center"/>

                                <TextBlock Text="{Binding}" 
                               FontSize="15" 
                               Padding="5" 
                               VerticalAlignment="Center"
                               Foreground="Black"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Erstellt:" FontSize="14" Foreground="Gray" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding CreatedAtFormatted}" Foreground="Gray" VerticalAlignment="Center" FontSize="14"/>
            </Grid>
        </StackPanel>

        <Button Grid.Row="0" Grid.Column="1" Width="200" Height="200" Margin="15" Click="Select_Photo_Click" Background="White" BorderBrush="Gray">
            <Grid>
                <Image x:Name="PhotoPreview" Stretch="UniformToFill"/>
                <TextBlock x:Name="PhotoPlaceholderText" Text="Foto auswählen" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible"/>
            </Grid>
        </Button>

        <GroupBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Header="Notizen" Margin="15" Foreground="Black" FontSize="16">
            <Grid>
                <RichTextBox x:Name="NotizenBox"
                     VerticalScrollBarVisibility="Auto"
                     PreviewKeyDown="NotizenBox_PreviewKeyDown"
                     TextChanged="NotizenBox_TextChanged" 
                     FontSize="16"
                     Padding="10"/>

                <TextBlock x:Name="PlaceholderText"
                   Text=" Hier kannst du Details zur Stelle, Ansprechpartner oder Fragen notieren..."
                   Foreground="LightGray"
                   Margin="15,12"
                   IsHitTestVisible="False"
                   Visibility="Visible"/>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="15,0,15,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="Bewerben!" 
                    Width="120" Height="40" 
                    FontSize="16" FontWeight="Bold" 
                    Background="#4CAF50" Foreground="White" 
                    Visibility="{Binding CanApply, Converter={StaticResource BoolToVisibilityConverter}}" 
                    Click="Apply_Click"/>

            <Button Grid.Column="1" 
                    Content="Schreiben fortsetzen" 
                    Width="180" Height="40" Margin="10,0,0,0" 
                    FontSize="16" Background="#2196F3" Foreground="White" 
                    Visibility="{Binding LastApplicationPath, Converter={StaticResource NullToVisibilityConverter}}" 
                    Click="ContinueButton_Click"/>

            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button Content="💡 Bewerbungstipps" Width="140" Height="40" Margin="5,0" Click="Tipps_Click" Tag="Bewerbungstipps"/>
                <Button Content="📝 Lebenslauftipps" Width="140" Height="40" Click="Tipps_Click" Tag="Lebenslauftipps"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>