<Page x:Class="Lehrstellensuchassistenz.Views.CompanyElement"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Lehrstellensuchassistenz.Views"
      xmlns:models="clr-namespace:Lehrstellensuchassistenz.Models"
      xmlns:converters="clr-namespace:Lehrstellensuchassistenz.Converters"
      xmlns:System="clr-namespace:System;assembly=mscorlib"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Firma Details">

    <Page.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:EnumDescriptionConverter x:Key="EnumDescConverter"/>

        <ObjectDataProvider x:Key="StatusEnumValues" 
                            MethodName="GetValues" 
                            ObjectType="{x:Type System:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:ApplicationStatus"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Page.Resources>

    <Grid Background="{StaticResource BackgroundBrush}" Focusable="True" MouseDown="Grid_MouseDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Margin="15,15,5,15">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Name:" FontSize="22" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" FontSize="22" Padding="5"/>
            </Grid>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Link:" FontSize="18" Foreground="Black" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Website, UpdateSourceTrigger=PropertyChanged}" FontSize="16" VerticalAlignment="Center" Padding="5"/>
                <Button Grid.Column="2" Width="35" Height="35" Margin="10,0,0,0" Content="↗" Click="OpenLink_Click" FontSize="18" Cursor="Hand"/>
            </Grid>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Status:" FontSize="18" Foreground="Black" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" HorizontalAlignment="Left" Width="280" Height="40" FontSize="16" 
                      ItemsSource="{Binding Source={StaticResource StatusEnumValues}}"
                      SelectedItem="{Binding Status, UpdateSourceTrigger=PropertyChanged}"
                      Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                      Foreground="White" FontWeight="SemiBold" VerticalContentAlignment="Center" Padding="10,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Ellipse Width="14" Height="14" Fill="{Binding Converter={StaticResource StatusToColorConverter}}" Margin="2,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Converter={StaticResource EnumDescConverter}}" FontSize="16" Foreground="Black" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </StackPanel>

        <Border Grid.Row="0" Grid.Column="1" Margin="15" 
            BorderBrush="#CCC" BorderThickness="1" CornerRadius="10" 
            Height="250" Width="250" Background="#F5F5F5" 
            MouseLeftButtonDown="Select_Photo_Click" Cursor="Hand"
            HorizontalAlignment="Right" VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" x:Name="PhotoPlaceholderText">
                    <TextBlock Text="📷" FontSize="50" HorizontalAlignment="Center" Foreground="#999"/>
                    <TextBlock Text="Firmenbild / Haus" FontSize="14" Foreground="#999" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <TextBlock Text="Klicken zum Auswählen" FontSize="11" Foreground="#AAA" HorizontalAlignment="Center"/>
                </StackPanel>

                <Image x:Name="PhotoPreview" Stretch="UniformToFill" Margin="2">
                    <Image.Clip>
                        <RectangleGeometry Rect="0,0,246,246" RadiusX="8" RadiusY="8"/>
                    </Image.Clip>
                </Image>
            </Grid>
        </Border>

        <GroupBox Grid.Row="1" Grid.ColumnSpan="2" Header="Notizen" Margin="15,5" FontSize="14" Foreground="#444">
            <Grid>
                <RichTextBox x:Name="NotizenBox" TextChanged="NotizenBox_TextChanged" PreviewKeyDown="NotizenBox_PreviewKeyDown"
                         AcceptsTab="True" Padding="12" FontSize="16" BorderThickness="0" Background="Transparent">
                    <RichTextBox.Resources>
                        <Style TargetType="{x:Type Paragraph}">
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="LineHeight" Value="24"/>
                        </Style>
                    </RichTextBox.Resources>
                </RichTextBox>

                <TextBlock x:Name="PlaceholderText" 
                       IsHitTestVisible="False" 
                       Text=" Schreibe hier wichtige Details, Ansprechpartner oder kopiere Infos rein..." 
                       VerticalAlignment="Top" HorizontalAlignment="Left" 
                       Margin="15,14,0,0" Foreground="#BBB" FontStyle="Italic" FontSize="16"
                       Visibility="Visible"/>
            </Grid>
        </GroupBox>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Padding="15" Background="#F0F0F0" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="BEWERBEN!" Width="180" Height="55" FontSize="22" FontWeight="Black" 
                    Background="#4CAF50" Foreground="White" BorderThickness="0"
                    Visibility="{Binding CanApply, Converter={StaticResource BoolToVisibilityConverter}}" 
                    Click="Apply_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Fortsetzen" Width="150" Height="55" Margin="15,0,0,0" FontSize="18" FontWeight="Bold"
                    Background="#2196F3" Foreground="White" BorderThickness="0"
                    Visibility="{Binding LastApplicationPath, Converter={StaticResource NullToVisibilityConverter}}" 
                    Click="ContinueButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="💡 Bewerbungstipps" Width="150" Height="34" Margin="5,0" 
                    Click="Tipps_Click" Tag="Bewerbungstipps" FontSize="13" Cursor="Hand"/>
                    <Button Content="📝 Lebenslauftipps" Width="150" Height="34" 
                    Click="Tipps_Click" Tag="Lebenslauftipps" FontSize="13" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>