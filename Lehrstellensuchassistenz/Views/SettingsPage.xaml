<Page x:Class="Lehrstellensuchassistenz.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Lehrstellensuchassistenz.Views"
      xmlns:lang="clr-namespace:Lehrstellensuchassistenz.Resources.Languages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="{x:Static lang:Langs.TitleSettings}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            <TextBlock Text="{x:Static lang:Langs.HeaderSettings}" FontSize="28" FontWeight="Bold" Margin="0,0,0,20" Foreground="Black"/>

            <GroupBox Header="{x:Static lang:Langs.GroupDataStorage}" Margin="0,0,0,20" Padding="10" FontSize="14">
                <StackPanel>
                    <TextBlock Text="{x:Static lang:Langs.LblCurrentStoragePath}" Margin="0,5" FontSize="14"/>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PathTextBox" IsReadOnly="True" VerticalAlignment="Center" Padding="5" Background="#F0F0F0"/>
                        <Button Grid.Column="1" Content="{x:Static lang:Langs.BtnChooseFolder}" Click="ChangeStoragePath_Click" Margin="10,0,0,0" Padding="10,5"/>
                    </Grid>
                    <TextBlock Text="{x:Static lang:Langs.HintRestartNote}" 
                               FontSize="12" Foreground="#D35400" FontStyle="Italic" Margin="0,5,0,0"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{x:Static lang:Langs.GroupQuicklinks}" Margin="0,0,0,20" Padding="10" FontSize="16">
                <StackPanel>
                    <TextBlock Text="{x:Static lang:Langs.LblAddCustomLinks}" FontSize="14" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtLinkName" Tag="{x:Static lang:Langs.WatermarkLinkName}" Margin="0,0,5,0" Padding="5"/>
                        <TextBox x:Name="TxtLinkUrl" Grid.Column="1" Tag="{x:Static lang:Langs.WatermarkLinkUrl}" Margin="0,0,5,0" Padding="5"/>
                        <Button Grid.Column="2" Content="{x:Static lang:Langs.BtnAdd}" Padding="15,5" Click="AddCustomLink_Click"/>
                    </Grid>

                    <Button Content="{x:Static lang:Langs.BtnManageLinks}" 
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0" 
                            Padding="15,5"
                            Click="ManageLinks_Click"/>

                    <ItemsControl x:Name="LinksList" Margin="0,15,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Button Content="{x:Static lang:Langs.BtnDelete}" HorizontalAlignment="Right" 
                                            Background="Transparent" Foreground="Red" BorderThickness="0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{x:Static lang:Langs.GroupGeneral}" Margin="0,0,0,20" Padding="10" FontSize="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Sprache / Language:" 
                       VerticalAlignment="Center" 
                       FontSize="14" 
                       Margin="0,0,10,0"/>
                        <ComboBox x:Name="ComboLanguage" 
                      Width="150" 
                      Padding="5"
                      SelectionChanged="ComboLanguage_SelectionChanged">
                            <ComboBoxItem Content="Deutsch" Tag="de-AT"/>
                            <ComboBoxItem Content="English" Tag="en-US"/>
                        </ComboBox>
                    </StackPanel>

                    <CheckBox x:Name="CbAutostart" 
                  Content="{x:Static lang:Langs.CheckAutostart}" 
                  FontSize="14" 
                  Checked="CbAutostart_Changed" 
                  Unchecked="CbAutostart_Changed"
                  Margin="0,0,0,10"/>

                    <Button Content="{x:Static lang:Langs.BtnCreateShortcut}" 
                HorizontalAlignment="Left" 
                Padding="15,5" 
                Click="CreateShortcut_Click"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{x:Static lang:Langs.GroupDangerZone}" BorderBrush="Red" Foreground="Red" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <CheckBox x:Name="CbDeleteAllUserData" 
                              Content="{x:Static lang:Langs.CheckDeleteUserData}" 
                              IsChecked="True" Margin="0,5"/>

                    <CheckBox x:Name="CbDeleteAppFolder" 
                              Content="{x:Static lang:Langs.CheckDeleteAppFolder}" 
                              Margin="0,5"/>

                    <Button Content="{x:Static lang:Langs.BtnStartCleanup}" 
                            Background="#FFE5E5" Foreground="DarkRed" FontWeight="Bold"
                            Margin="0,15,0,0" Padding="10"
                            Click="DeleteAllData_Click"/>
                </StackPanel>
            </GroupBox>

            <TextBlock Text="Developed by Zhengxin Ye" 
                       FontSize="13" 
                       Foreground="#777777" 
                       HorizontalAlignment="Center" 
                       Margin="0,15,0,10" 
                       FontWeight="SemiBold"/>
        </StackPanel>
    </ScrollViewer>
</Page>