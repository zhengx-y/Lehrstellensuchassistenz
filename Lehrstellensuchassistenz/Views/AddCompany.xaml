<Window x:Class="Lehrstellensuchassistenz.Views.AddCompany"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lehrstellensuchassistenz.Views"
        xmlns:lang="clr-namespace:Lehrstellensuchassistenz.Resources.Languages"
        mc:Ignorable="d"
        Title="{x:Static lang:Langs.TitleAddCompany}"
        Height="200" Width="350"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Loaded="Window_Loaded">

    <StackPanel Margin="20">
        <TextBlock Text="{x:Static lang:Langs.LblQuestionCompanyName}" 
                   FontSize="14"
                   Foreground="Black" 
                   Margin="0,0,0,10"/>

        <TextBox x:Name="InputTextBox" 
                 FontSize="18" 
                 Height="35" 
                 VerticalContentAlignment="Center"
                 Padding="5,0"
                 Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{x:Static lang:Langs.BtnAdd}" 
                    Width="100" Height="30" 
                    Margin="0,0,10,0" 
                    Click="Ok_Click" 
                    IsDefault="True"
                    Background="#4CAF50" 
                    Foreground="White"
                    FontWeight="Bold"/>

            <Button Content="{x:Static lang:Langs.BtnCancel}" 
                    Width="90" Height="30" 
                    Click="Cancel_Click" 
                    IsCancel="True"
                    Background="Transparent"
                    Foreground="Gray"/>
        </StackPanel>
    </StackPanel>
</Window>