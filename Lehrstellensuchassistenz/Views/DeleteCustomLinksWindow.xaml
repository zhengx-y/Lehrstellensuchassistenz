<Window x:Class="Lehrstellensuchassistenz.Views.DeleteCustomLinksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Links verwalten" Height="400" Width="350" 
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Links zum Löschen auswählen:" 
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

        <ListBox x:Name="LinksListBox" Grid.Row="1" Margin="0,0,0,15" Padding="5">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Name}" 
                              Tag="{Binding}" 
                              FontSize="14" Margin="5"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Abbrechen" Width="90" Height="30" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Löschen" Width="90" Height="30" 
                    Background="#E57373" Foreground="White" FontWeight="Bold"
                    Click="DeleteSelected_Click"/>
        </StackPanel>
    </Grid>
</Window>