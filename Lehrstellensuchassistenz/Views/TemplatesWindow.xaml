<Window x:Class="Lehrstellensuchassistenz.Views.TemplatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bewerbungsvorlagen auswählen"
        Height="800" Width="1400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="25">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="25"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="25"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Image Source="/Resources/Images/generische_vorlage.png"
                   Width="420" Height="620"
                   Stretch="Uniform"
                   VerticalAlignment="Center" Grid.Row="0"/>

            <Button Content="Generische Vorlage wählen"
                    Width="180" Height="35"
                    Margin="0,10,0,0"
                    Grid.Row="1"
                    Click="SelectGenericTemplate_Click"/>

            <Button Content="Hidden" Visibility="Hidden" Height="35" Grid.Row="2" Margin="0,10,0,0"/>
        </Grid>

        <Grid Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Width="420" Height="620"
                    Background="#EEE" BorderBrush="Gray" BorderThickness="1"
                    CornerRadius="12" Grid.Row="0">
                <TextBlock Text="Vorschau Eigene Vorlage"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="Gray" FontSize="20" FontWeight="SemiBold"/>
            </Border>

            <Button Content="Eigene Vorlage verwenden"
                    Width="180" Height="35"
                    Margin="0,10,0,0"
                    Grid.Row="1"
                    Click="UseCustomTemplate_Click"/>

            <Button Content="Eigene Vorlage hochladen"
                    Width="180" Height="35"
                    Margin="0,10,0,0"
                    Grid.Row="2"
                    Click="UploadCustomTemplate_Click"/>
        </Grid>

        <Grid Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Image Source="/Resources/Images/leeres_dokument.png"
                   Width="420" Height="620"
                   Stretch="Uniform" Grid.Row="0"/>

            <Button Content="Leeres Dokument wählen"
                    Width="180" Height="35"
                    Margin="0,10,0,0"
                    Grid.Row="1"
                    Click="SelectEmptyTemplate_Click"/>

            <Button Content="Hidden" Visibility="Hidden" Height="35" Grid.Row="2" Margin="0,10,0,0"/>
        </Grid>
    </Grid>
</Window>