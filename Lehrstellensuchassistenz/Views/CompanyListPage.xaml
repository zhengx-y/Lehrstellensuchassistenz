<Page x:Class="Lehrstellensuchassistenz.Views.CompanyListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Lehrstellensuchassistenz.Views"
      xmlns:converters="clr-namespace:Lehrstellensuchassistenz.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      UseLayoutRounding="True" 
      TextOptions.TextFormattingMode="Display"
      TextOptions.TextRenderingMode="ClearType"
      Title="Deine Bewerbungen">

    <Page.Resources>
        <!-- Achte darauf, dass der Converter im Namespace .Converters liegt -->
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
    </Page.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <ListBox x:Name="CompanyListBox"
                 Margin="15"
                 Background="Transparent"
                 BorderThickness="0"
                 MouseDoubleClick="CompanyListBox_MouseDoubleClick"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,-5" Background="Transparent">

                        <Border Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}" 
                    CornerRadius="10" 
                    SnapsToDevicePixels="True"
                    Margin="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" 
                                      ShadowDepth="2" 
                                      Opacity="0.4" 
                                      Color="Black"
                                      RenderingBias="Quality"/>
                            </Border.Effect>
                        </Border>

                        <Border Background="Transparent" 
                    Padding="20"
                    Margin="10"
                    SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Name}" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="White"
                               VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" 
                                VerticalAlignment="Center" 
                                Margin="25,0,15,0" 
                                Opacity="0.8">
                                    <TextBlock Text="Zuletzt aktualisiert:" 
                                   FontSize="10" 
                                   Foreground="White" 
                                   HorizontalAlignment="Right"
                                   Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding LastModified, StringFormat={}{0:dd.MM.yyyy HH:mm}}" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Foreground="White" 
                                   HorizontalAlignment="Right"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" 
                               Text="{Binding Status}" 
                               FontSize="16" 
                               FontWeight="Medium"
                               Foreground="White" 
                               Opacity="0.95"
                               VerticalAlignment="Center" 
                               MinWidth="100"
                               TextAlignment="Right"/>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <!-- Entfernt das hässliche Standard-Blau beim Auswählen -->
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter x:Name="Content" />
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Content" Property="Opacity" Value="0.85"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Content" Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="0.99" ScaleY="0.99"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

        </ListBox>
    </Grid>
</Page>