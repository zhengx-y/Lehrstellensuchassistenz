<Window x:Class="Lehrstellensuchassistenz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lehrstellensuchassistenz"
        mc:Ignorable="d"
        Title="Lehrstellensuchassistenz v1.0.0-alpha"
        Height="720"
        Width="1280"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Background="{StaticResource BackgroundBrush}">

        <!-- RowDefinitions: Top Buttons, Bar, Main Content -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Top Buttons -->
            <RowDefinition Height="5"/>
            <!-- Top horizontal bar -->
            <RowDefinition/>
            <!-- Main Content -->
        </Grid.RowDefinitions>

        <!-- Top Buttons Row -->
        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Left buttons -->
                <ColumnDefinition Width="Auto"/>
                <!-- Right: Sort / Add -->
            </Grid.ColumnDefinitions>

            <!-- Left Buttons -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Zurück" Width="60" Height="40" Margin="0,0,10,0" Click="ReturnPage_Click"/>
                <Button Content="Alle Änderungen Bisher Speichern" Width="200" Height="40" Margin="0,0,10,0" Click="SaveCompanies_Click"/>
                <Button Content="Ausgewählte Element Löschen" Width="180" Height="40" Click="Delete_Click"/>
            </StackPanel>

            <!-- Right Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <ComboBox x:Name="SortComboBox"
          Width="160" Height="40" Margin="0,0,10,0"
          SelectionChanged="SortComboBox_SelectionChanged"
          HorizontalContentAlignment="Left"
          VerticalContentAlignment="Center"
          SelectedIndex="0">
                    <!-- Platzhalter -->
                    <ComboBoxItem IsEnabled="False" Content="Sortieren" />

                    <!-- Datum -->
                    <ComboBoxItem Content="Älteste" Tag="DateAsc"/>
                    <ComboBoxItem Content="Neueste" Tag="DateDesc"/>

                    <!-- Name -->
                    <ComboBoxItem Content="Name A→Z" Tag="NameAsc"/>
                    <ComboBoxItem Content="Name Z→A" Tag="NameDesc"/>
                </ComboBox>

                <Button Content="Unternehmen hinzufügen" Width="150" Height="40" Click="AddCompany_Click"/>
            </StackPanel>
        </Grid>

        <!-- Top Horizontal Bar -->
        <Border Grid.Row="1" Background="{StaticResource PrimaryBrush}" HorizontalAlignment="Stretch"/>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <!-- Sidebar -->
                <ColumnDefinition Width="5"/>
                <!-- Separator -->
                <ColumnDefinition Width="*"/>
                <!-- Frame -->
            </Grid.ColumnDefinitions>

            <!-- Sidebar Buttons -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Top">
                    <Button Content="Lebenslauf" Width="180" Height="40" Margin="10" Background="LightGreen" Click="Lebenslauf_Click"/>

                    <!-- Neuer Button: Bewerbungen -->
                    <Button Content="Bewerbungen" Width="180" Height="40" Margin="10" Background="LightBlue" Click="OpenBewerbungen_Click"/>

                    <Button Content="AMS" Width="180" Height="40" Margin="10" Click="Link_Click"/>
                    <Button Content="karriere.at" Width="180" Height="40" Margin="10" Click="Link_Click"/>
                    <Button Content="WKO" Width="180" Height="40" Margin="10" Click="Link_Click"/>
                    <Button Content="lehrstelle.at" Width="180" Height="40" Margin="10" Click="Link_Click"/>
                    <Button Content="lehrstellenportal.at" Width="180" Height="40" Margin="10" Click="Link_Click"/>
                    <Button Content="DevJobs" Width="180" Height="40" Margin="10" Click="Link_Click"/>
                    <Button Content="Einstellungen" Width="180" Height="40" Margin="10" Background="DarkGray" Click="Sort_Click"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Vertical Separator -->
            <Border Grid.Column="1" Background="{StaticResource PrimaryBrush}" HorizontalAlignment="Stretch"/>

            <!-- Main Frame -->
            <Frame x:Name="MainFrame" Grid.Column="2" Margin="10" NavigationUIVisibility="Hidden"/>
        </Grid>

    </Grid>
</Window>