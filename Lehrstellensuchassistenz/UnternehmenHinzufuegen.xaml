<Window x:Class="Lehrstellensuchassistenz.UnternehmenHinzufuegen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lehrstellensuchassistenz"
        mc:Ignorable="d"
        Title="Neuen Firmennamen eingeben"
        Height="150" Width="300"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <StackPanel Margin="10">
        <TextBlock Text="Firmenname:" Margin="0,0,0,5"/>
        <TextBox x:Name="InputTextBox" FontSize="16" Height="25" Margin="0,5,0,10"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="60" Height="25" Margin="0,0,5,0" Click="Ok_Click" IsDefault="True"/>
            <Button Content="Abbrechen" Width="80" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
