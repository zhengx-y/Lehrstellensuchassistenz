<Page x:Class="Lehrstellensuchassistenz.CompanyListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Lehrstellensuchassistenz"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CompanyListPage">

    <Grid>
        <!-- ListBox -->
        <ListBox x:Name="CompanyListBox"
                 Margin="10"
                 Background="{StaticResource BackgroundBrush}"
                 BorderThickness="0"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 FontSize="80"
                 Padding="5"
                 MouseDoubleClick="CompanyListBox_MouseDoubleClick"
                 DisplayMemberPath="Name"/>
    </Grid>
</Page>
