<Window x:Class="Lehrstellensuchassistenz.VorlagenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bewerbungsvorlagen auswählen"
        Height="800" Width="1400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="25">
        <!-- Definiere 5 Spalten für die Vorlagen -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="25"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="25"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Definiere 4 Zeilen für die Vorlagen -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <!-- Bildbereich, anpassbar -->
            <RowDefinition Height="Auto"/>
            <!-- Button 1 -->
            <RowDefinition Height="Auto"/>
            <!-- Button 2 -->
        </Grid.RowDefinitions>

        <!-- 🔹 Generische Vorlage -->
        <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Bild -->
            <Image Source="/resources/images/generische_vorlage.png"
                   Width="420"
                   Height="620"
                   Stretch="Uniform"
                   VerticalAlignment="Center" Grid.Row="0"/>

            <!-- Button für Generische Vorlage -->
            <Button Content="Generische Vorlage wählen"
                    Width="150"
                    Height="28"
                    Margin="0,8,0,0"
                    Grid.Row="1"
                    VerticalAlignment="Top"
                    Click="GenerischeVorlage_Click"/>

            <!-- Button für Weitere Aktion (unsichtbar, Platz bleibt erhalten) -->
            <!-- Der Button ist unsichtbar, aber der Platz bleibt erhalten -->
            <Button Content="Weitere Aktion"
                    Width="150"
                    Height="28"
                    Margin="0,8,0,0"
                    Grid.Row="2"
                    VerticalAlignment="Top"
                    Visibility="Hidden"/>
        </Grid>

        <!-- 🔹 Eigene Vorlage -->
        <Grid Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Bild -->
            <Border Width="420"
                    Height="620"
                    Background="#EEE"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="12"
                    VerticalAlignment="Center"
                    Grid.Row="0">
                <TextBlock Text="Platzhalter Bild"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="Gray"
                           FontSize="24"
                           FontWeight="SemiBold"/>
            </Border>

            <!-- Button für Eigene Vorlage verwenden -->
            <Button Content="Eigene Vorlage verwenden"
                    Width="150"
                    Height="28"
                    Margin="0,8,0,0"
                    Grid.Row="1"
                    VerticalAlignment="Top"
                    Click="EigeneVorlage_Click"/>

            <!-- Button für Eigene Vorlage hochladen -->
            <Button Content="Eigene Vorlage hochladen"
                    Width="150"
                    Height="28"
                    Margin="0,8,0,0"
                    Grid.Row="2"
                    VerticalAlignment="Top"
                    Click="EigeneVorlageHochladen_Click"/>

            <!-- Button für Weitere Aktion (unsichtbar, Platz bleibt erhalten) -->
            <!-- Der Button ist unsichtbar, aber der Platz bleibt erhalten -->
            <Button Content="Weitere Aktion"
                    Width="150"
                    Height="28"
                    Margin="0,8,0,0"
                    Grid.Row="3"
                    VerticalAlignment="Top"
                    Visibility="Hidden"/>
        </Grid>

        <!-- 🔹 Leeres Dokument -->
        <Grid Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Bild -->
            <Image Source="/resources/images/leeres_dokument.png"
                   Width="420"
                   Height="620"
                   Stretch="Uniform"
                   VerticalAlignment="Center"
                   Grid.Row="0"/>

            <!-- Button für Leeres Dokument wählen -->
            <Button Content="Leeres Dokument wählen"
                    Width="150"
                    Height="28"
                    Margin="0,8,0,0"
                    Grid.Row="1"
                    VerticalAlignment="Top"
                    Click="LeeresDokument_Click"/>

            <!-- Button für Weitere Aktion (unsichtbar, Platz bleibt erhalten) -->
            <!-- Der Button ist unsichtbar, aber der Platz bleibt erhalten -->
            <Button Content="Weitere Aktion"
                    Width="150"
                    Height="28"
                    Margin="0,8,0,0"
                    Grid.Row="2"
                    VerticalAlignment="Top"
                    Visibility="Hidden"/>
        </Grid>

    </Grid>
</Window>